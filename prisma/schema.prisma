generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Marca / cliente ─────────────────────────────────────────────────────────

model Brand {
  id          String   @id @default(cuid())
  name        String
  segment     String   @default("Outro")
  color       String   @default("#1A1A1A")
  cnpj        String?
  site        String?
  contact     String?
  description String?
  boilerplate String?
  authors     String[]
  logoUrl     String?
  toneConfig  Json?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  releases    Release[]
  members     BrandMember[]
}

// ─── Release ─────────────────────────────────────────────────────────────────

model Release {
  id                   String        @id @default(cuid())
  title                String
  body                 String        @db.Text
  summary              String?
  status               ReleaseStatus @default(DRAFT)
  scheduledAt          DateTime?
  publishedAt          DateTime?
  creditsUsed          Int           @default(0)
  aiCreditsUsed        Int           @default(0)
  imageUrl             String?
  vehicles             String[]
  adminNotes           String?
  publishedVehicleUrls Json?
  brandId              String
  authorId             String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  brand       Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

enum ReleaseStatus {
  DRAFT
  SCHEDULED
  IN_REVIEW
  NEEDS_REVISION
  REJECTED
  IN_PUBLICATION
  PUBLISHED
  CANCELLED
}

// ─── Equipe ──────────────────────────────────────────────────────────────────

model TeamMember {
  id        String       @id @default(cuid())
  clerkId   String       @unique
  email     String
  name      String
  role      TeamRole     @default(EDITOR)
  status    MemberStatus @default(ACTIVE)
  ownerId   String
  createdAt DateTime     @default(now())

  brands    BrandMember[]
}

model BrandMember {
  brandId      String
  teamMemberId String

  brand        Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  member       TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@id([brandId, teamMemberId])
}

enum TeamRole {
  ADMIN
  EDITOR
  REVIEWER
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
}

// ─── Veículo (gerenciado por admins Raio) ────────────────────────────────────

model Vehicle {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  category  String
  tier      String
  reach     Int
  logoUrl   String?
  site      String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Assinatura ──────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  ownerId              String             @unique
  plan                 PlanTier
  highestPlan          PlanTier?
  status               SubscriptionStatus @default(INACTIVE)
  creditsTotal         Int
  creditsUsed          Int                @default(0)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum PlanTier {
  BASIC
  ADVANCED
  PROFESSIONAL
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
}

// ─── Convite ─────────────────────────────────────────────────────────────────

model Invite {
  id        String   @id @default(cuid())
  email     String
  role      TeamRole @default(EDITOR)
  brandIds  String[]
  token     String   @unique @default(cuid())
  ownerId   String
  sentAt    DateTime @default(now())
  expiresAt DateTime
  accepted  Boolean  @default(false)
}

// ─── Notificações ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  prefs     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vouchers de crédito ─────────────────────────────────────────────────────

model Voucher {
  id          String    @id @default(cuid())
  code        String    @unique
  credits     Int
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  description String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  redemptions VoucherRedemption[]
}

model VoucherRedemption {
  id         String   @id @default(cuid())
  voucherId  String
  userId     String
  redeemedAt DateTime @default(now())

  voucher    Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
}

// ─── Suporte ──────────────────────────────────────────────────────────────────

model SupportConversation {
  id        String           @id @default(cuid())
  ownerId   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]
  ticket    SupportTicket?
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           String              // "user" | "assistant"
  content        String
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id             String              @id @default(cuid())
  conversationId String              @unique
  ownerId        String
  subject        String
  description    String
  status         String              @default("open") // "open" | "closed"
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
